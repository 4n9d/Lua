                    if oA and oB and sA.Z>0 and sB.Z>0 then
                        ln.From=Vector2.new(sA.X,sA.Y);ln.To=Vector2.new(sB.X,sB.Y)
                        ln.Color=espCfg.skelCol;ln.Thickness=1.5;ln.Visible=true
                    else ln.Visible=false end
                elseif ln then ln.Visible=false end
            end
            for i=#bd+1,MAXB do if o.bones[i] then o.bones[i].Visible=false end end
        else for _,b in ipairs(o.bones) do b.Visible=false end end

        if espCfg.name then
