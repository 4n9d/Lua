        local hum=char:FindFirstChildOfClass("Humanoid")
        local hrp=char:FindFirstChild("HumanoidRootPart")
        local head=char:FindFirstChild("Head")
        if not hum or not hrp or not head or hum.Health<=0 then hideESP(o); continue end
        local dist=(mp-hrp.Position).Magnitude
        if dist>espCfg.maxDist then hideESP(o); continue end
        local hsp,hon=cam:WorldToViewportPoint(head.Position)
