local AB = {on=false,part="Head",team=false,vis=false,fov=150,drawFov=false,dynFov=false,lockMode="Soft",curvePct=10,speed=1.0,speedAttack=1.0,speedScaleFov=50,maxLock=3.0,reactTime=100,useCenter=false}
local abTgt,abLockT,abReactT = nil,0,0
