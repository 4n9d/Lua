end

local function destroyESPObjects(p)
    local obj = espPool[p]; if not obj then return end
    local keys = {"bT","bB","bL","bR","cTLh","cTLv","cTRh","cTRv","cBLh","cBLv","cBRh","cBRv","fill","nameTag","weaponTag","distTag","hpBg","hpFg"}
    for _,k in ipairs(keys) do pcall(function() obj[k]:Remove() end) end
    for _,bone in ipairs(obj.bones) do pcall(function() bone:Remove() end) end
    espPool[p]=nil
end

local function hideObj(obj)
    if not obj then return end
    local keys = {"bT","bB","bL","bR","cTLh","cTLv","cTRh","cTRv","cBLh","cBLv","cBRh","cBRv","fill","nameTag","weaponTag","distTag","hpBg","hpFg"}
    for _,k in ipairs(keys) do if obj[k] then obj[k].Visible=false end end
    for _,bone in ipairs(obj.bones) do bone.Visible=false end
end

local function getBox(hrp, head)
    local rootPos, headTop = hrp.Position, head.Position+Vector3.new(0,0.6,0)
    local yTop, yBot, hw = headTop.Y-rootPos.Y, -3.0, 1.05
    local corners = {Vector3.new(rootPos.X-hw,rootPos.Y+yBot,rootPos.Z-hw),Vector3.new(rootPos.X+hw,rootPos.Y+yBot,rootPos.Z-hw),Vector3.new(rootPos.X-hw,rootPos.Y+yBot,rootPos.Z+hw),Vector3.new(rootPos.X+hw,rootPos.Y+yBot,rootPos.Z+hw),Vector3.new(rootPos.X-hw,rootPos.Y+yTop,rootPos.Z-hw),Vector3.new(rootPos.X+hw,rootPos.Y+yTop,rootPos.Z-hw),Vector3.new(rootPos.X-hw,rootPos.Y+yTop,rootPos.Z+hw),Vector3.new(rootPos.X+hw,rootPos.Y+yTop,rootPos.Z+hw)}
    local minX,minY,maxX,maxY,any = math.huge,math.huge,-math.huge,-math.huge,false
    for _,corner in ipairs(corners) do
        local sp,onScreen = cam:WorldToViewportPoint(corner)
        if onScreen and sp.Z>0 then
            any=true
            if sp.X<minX then minX=sp.X end
            if sp.Y<minY then minY=sp.Y end
            if sp.X>maxX then maxX=sp.X end
            if sp.Y>maxY then maxY=sp.Y end
        end
    end
    if not any then return nil end
    local vx,vy = cam.ViewportSize.X, cam.ViewportSize.Y
    minX=math.clamp(minX,0,vx);minY=math.clamp(minY,0,vy);maxX=math.clamp(maxX,0,vx);maxY=math.clamp(maxY,0,vy)
    local w,h = maxX-minX, maxY-minY
    if w<2 or h<2 then return nil end
    return minX,minY,w,h
end

local function getHPColor(pct)
    if not espCfg.healthBarGradient then return Color3.fromRGB(60,220,60) end
    pct = math.clamp(pct,0,1)
    if pct>=0.5 then local t=(pct-0.5)/0.5;return Color3.fromRGB(math.floor(255*(1-t)),210,0)
    else local t=pct/0.5;return Color3.fromRGB(210,math.floor(210*t),0) end
end

local function getWeapon(char)
    if not char then return "None" end
    local p = Players:GetPlayerFromCharacter(char)
    if p then
        local n = p:GetAttribute("EquippedItemName") or p:GetAttribute("EquippedItem") or p:GetAttribute("WeaponName") or p:GetAttribute("Weapon")
        if n and type(n)=="string" and n~="" then return n end
    end
    local cn = char:GetAttribute("EquippedItemName") or char:GetAttribute("EquippedItem") or char:GetAttribute("WeaponName") or char:GetAttribute("Weapon")
    if cn and type(cn)=="string" and cn~="" then return cn end
    if p==lp and FighterController and FighterController.LocalFighter then
        local ok,name = pcall(function() local item = FighterController.LocalFighter.EquippedItem; if item then local v = item:Get("Name"); if v then return v end end end)
        if ok and name then return name end
    end
    for _,v in ipairs(char:GetChildren()) do
        if v:IsA("Model") and v.Name~="Animate" then
            local l = v.Name:lower()
            if not l:find("accessor") and not l:find("hair") then return v.Name end
        end
    end
    for _,v in ipairs(char:GetChildren()) do if v:IsA("Tool") then return v.Name end end
    return "None"
end

