local function safeRequire(inst)
    if not inst then return nil end
    local ok, r = pcall(require, inst)
    return ok and r or nil
end

local function safeWFC(parent, name, t)
    if not parent then return nil end
    local ok, r = pcall(function() return parent:WaitForChild(name, t or 5) end)
    return ok and r or nil
end

local function waitForModule(parent, name, timeout)
    if not parent then return nil end
    local t = 0
    while not parent:FindFirstChild(name) and t < (timeout or 10) do
        task.wait(0.5); t = t + 0.5
    end
    return parent:FindFirstChild(name)
end

