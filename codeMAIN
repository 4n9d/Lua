local function createESPObjects(p)
    if espPool[p] then return end
    local obj = {bT=newLine(),bB=newLine(),bL=newLine(),bR=newLine(),cTLh=newLine({ZIndex=6}),cTLv=newLine({ZIndex=6}),cTRh=newLine({ZIndex=6}),cTRv=newLine({ZIndex=6}),cBLh=newLine({ZIndex=6}),cBLv=newLine({ZIndex=6}),cBRh=newLine({ZIndex=6}),cBRv=newLine({ZIndex=6}),fill=newSquare(),nameTag=newText({Size=13}),weaponTag=newText({Size=11,Color=Color3.fromRGB(160,160,255)}),distTag=newText({Size=11,Color=Color3.fromRGB(180,180,180)}),hpBg=newLine({ZIndex=5,Thickness=5,Color=Color3.new(0,0,0)}),hpFg=newLine({ZIndex=6,Thickness=3,Color=Color3.fromRGB(60,220,60)}),bones={}}
