    boxThick=1,skelThick=1,nameSize=13,weaponSize=11,distSize=11,
    hpWidth=3,hpOffset=5,
}

-- Per-player drawing object table
-- Created lazily, never throttled
-- All updates happen every frame for smooth tracking
local espPool = {}

local SKELETON_R15 = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},
    {"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},
    {"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},
    {"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},
    {"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},
    {"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"},
}
local SKELETON_R6 = {
    {"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},
    {"Torso","Left Leg"},{"Torso","Right Leg"},
}
local MAX_BONES = math.max(#SKELETON_R15, #SKELETON_R6)

local function newDraw(t, props)
    local d = Drawing.new(t)
    if props then for k,v in pairs(props) do d[k]=v end end
    return d
end

-- Creates all drawings for a player upfront
local function createESPForPlayer(p)
    if espPool[p] then return end
    local obj = {
        -- Box (4 edges)
        bT=newDraw("Line",{Visible=false,ZIndex=5,Thickness=1,Color=Color3.new(1,0,0)}),
        bB=newDraw("Line",{Visible=false,ZIndex=5,Thickness=1,Color=Color3.new(1,0,0)}),
        bL=newDraw("Line",{Visible=false,ZIndex=5,Thickness=1,Color=Color3.new(1,0,0)}),
        bR=newDraw("Line",{Visible=false,ZIndex=5,Thickness=1,Color=Color3.new(1,0,0)}),
        -- Outline (drawn behind box for contrast)
        oT=newDraw("Line",{Visible=false,ZIndex=4,Thickness=3,Color=Color3.new(0,0,0)}),
        oB=newDraw("Line",{Visible=false,ZIndex=4,Thickness=3,Color=Color3.new(0,0,0)}),
        oL=newDraw("Line",{Visible=false,ZIndex=4,Thickness=3,Color=Color3.new(0,0,0)}),
        oR=newDraw("Line",{Visible=false,ZIndex=4,Thickness=3,Color=Color3.new(0,0,0)}),
        -- Fill
        fill=newDraw("Square",{Visible=false,ZIndex=3,Filled=true,Color=Color3.new(1,1,1),Transparency=0.7}),
        -- Text labels
        nameTag  =newDraw("Text",{Visible=false,ZIndex=7,Size=13,Center=true,Outline=true,Font=Drawing.Fonts.UI,Color=Color3.new(1,1,1)}),
        weaponTag=newDraw("Text",{Visible=false,ZIndex=7,Size=11,Center=true,Outline=true,Font=Drawing.Fonts.UI,Color=Color3.fromRGB(180,180,255)}),
        distTag  =newDraw("Text",{Visible=false,ZIndex=7,Size=11,Center=true,Outline=true,Font=Drawing.Fonts.UI,Color=Color3.fromRGB(200,200,200)}),
        -- Health bar
        hpBg=newDraw("Line",{Visible=false,ZIndex=5,Thickness=5,Color=Color3.new(0,0,0)}),
        hpFg=newDraw("Line",{Visible=false,ZIndex=6,Thickness=3,Color=Color3.fromRGB(60,220,60)}),
        -- Skeleton lines
        bones={},
    }
    for i=1,MAX_BONES do
        obj.bones[i]=newDraw("Line",{Visible=false,ZIndex=5,Thickness=1,Color=Color3.fromRGB(255,255,0)})
    end
    espPool[p]=obj
end

local function destroyESPForPlayer(p)
    local obj=espPool[p]; if not obj then return end
    local keys={"bT","bB","bL","bR","oT","oB","oL","oR","fill","nameTag","weaponTag","distTag","hpBg","hpFg"}
    for _,k in ipairs(keys) do pcall(function()obj[k]:Remove()end) end
    for _,bone in ipairs(obj.bones) do pcall(function()bone:Remove()end) end
    espPool[p]=nil
end

local function hideESP(obj)
    if not obj then return end
    obj.bT.Visible=false;obj.bB.Visible=false;obj.bL.Visible=false;obj.bR.Visible=false
    obj.oT.Visible=false;obj.oB.Visible=false;obj.oL.Visible=false;obj.oR.Visible=false
    obj.fill.Visible=false;obj.nameTag.Visible=false;obj.weaponTag.Visible=false
    obj.distTag.Visible=false;obj.hpBg.Visible=false;obj.hpFg.Visible=false
    for _,bone in ipairs(obj.bones) do bone.Visible=false end
end

-- Get 2D bounding box from character using head+HRP positions
-- Smooth because it uses actual part positions every frame
local function getBox(char)
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return nil end

    -- Use 8 corners of a character-sized box
    local root = hrp.CFrame
    local halfW = 1.2
    local yBot  = -3.2
    local yTop  = (head.Position.Y - hrp.Position.Y) + 1.2

    local corners = {
        root*Vector3.new(-halfW, yBot, -halfW),
        root*Vector3.new( halfW, yBot, -halfW),
        root*Vector3.new(-halfW, yBot,  halfW),
        root*Vector3.new( halfW, yBot,  halfW),
        root*Vector3.new(-halfW, yTop, -halfW),
        root*Vector3.new( halfW, yTop, -halfW),
        root*Vector3.new(-halfW, yTop,  halfW),
        root*Vector3.new( halfW, yTop,  halfW),
    }

    local minX,minY,maxX,maxY = math.huge,math.huge,-math.huge,-math.huge
    local anyVisible = false

    for _,c in ipairs(corners) do
        local sp,on = cam:WorldToViewportPoint(c)
        if on and sp.Z > 0 then
            anyVisible = true
            if sp.X < minX then minX=sp.X end
            if sp.Y < minY then minY=sp.Y end
            if sp.X > maxX then maxX=sp.X end
            if sp.Y > maxY then maxY=sp.Y end
        end
    end

    if not anyVisible then return nil end
    return minX, minY, maxX-minX, maxY-minY
end

local function getHPColor(pct)
    if not espCfg.healthBarGradient then return Color3.fromRGB(60,220,60) end
    pct=math.clamp(pct,0,1)
    if pct>=0.5 then
        local t=(pct-0.5)/0.5
        return Color3.fromRGB(math.floor(255*(1-t)),200,0)
    else
        local t=pct/0.5
        return Color3.fromRGB(210,math.floor(200*t),0)
    end
end

local function getWeapon(char)
    for _,v in ipairs(char:GetChildren()) do if v:IsA("Tool") then return v.Name end end
    return "None"
end

