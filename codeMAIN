RunService.RenderStepped:Connect(function(dt)
    cam = ws.CurrentCamera
    Library:SetWatermark("Rivals v2.1")

    pcall(renderESP)

    if AB.on and CameraController then
        if abDoReact then abReactT-=dt; if abReactT<=0 then abDoReact=false end end
        if not abDoReact then
            if abTgt and not abTgtValid(abTgt) then abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0 end
            if not abTgt then
                abTgt=abFind()
                if abTgt then abLockT=0;abDoReact=true;abReactT=AB.reactTime/1000;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0 end
            end
            if abTgt then
                abLockT+=dt
                if abLockT>AB.maxLock then abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0
                elseif inFov(abTgt, abEffFov()) then
                    pcall(function()
                        local aimPos = getPredictedPos(abTgt)
                        local du = (aimPos-cam.CFrame.Position).Unit
                        local tRot = Vector2.new(math.asin(math.clamp(du.Y,-1,1)),math.atan2(-du.X,-du.Z))
                        local cur = CameraController.Rotation
                        local sp,_ = cam:WorldToViewportPoint(aimPos)
                        local sd = (Vector2.new(sp.X,sp.Y)-getScr()).Magnitude
                        local newRot = applySmartLock(tRot,cur,dt,sd,abEffFov())
                        CameraController:ApplyRotationDelta(Vector2.new(newRot.X-cur.X,angDiff(cur.Y,newRot.Y)))
                    end)
                else abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0 end
            end
        end
    end

    if fovCfg.visible then
        local center = fovCfg.useCenter and getScr() or getMousePos()
        fovCircle.Visible=true;fovCircle.Color=fovCfg.color;fovCircle.Position=center
        fovCircle.Radius = fovCfg.fovSize
    else fovCircle.Visible=false;fovHalf.Visible=false;abCirc.Visible=false end

    if silentCfg.enabled and silentCfg.circleVisible then
        local center = silentCfg.useCenter and getScr() or getMousePos()
        silentCircle.Visible=true;silentCircle.Radius=silentCfg.fovSize
        silentCircle.Thickness=silentCfg.circleThick;silentCircle.Position=center
        silentCircle.Color=silentCfg.circleColor
    else silentCircle.Visible=false end
end)

