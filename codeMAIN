RunService.RenderStepped:Connect(function(dt)
    cam = ws.CurrentCamera

    pcall(doESP)

    pcall(function()
        local CC=Mods.CameraController; if not CC then return end
        if camCfg.fovOn then CC._base_fov=camCfg.fovVal end
        if camCfg.noShake then CC._shake_enabled=false; CC.ShakeCFrame=CFrame.identity end
        if camCfg.noSway then CC._sway_spring.Value=Vector2.zero; CC._sway_spring.Target=Vector2.zero end
        if camCfg.noBob then
            CC._bobbing_speed_spring.Target=0; CC._bobbing_speed_spring.Value=0
            CC._bobbing_value_spring.Target=0; CC._bobbing_value_spring.Value=0
        end
        if camCfg.noJump then CC._jump_spring.Target=0; CC._jump_spring.Value=0 end
        if camCfg.noTilt then CC._sliding_spring.Target=0; CC._sliding_spring.Value=0 end
        if camCfg.forceCross then CC._crosshair_disabled=false end
        if camCfg.sensOn then
            CC._camera_sensitivity=camCfg.sens
            CC._camera_sensitivity_ads_multiplier=camCfg.sensADS
            CC._camera_sensitivity_ads_multiplier_scoped=camCfg.sensScope
            CC._camera_sensitivity_x=camCfg.sensX
            CC._camera_sensitivity_y=camCfg.sensY
        end
        if camCfg.vmOn then CC.ViewModelOffsetCFrame=CFrame.new(camCfg.vmX,camCfg.vmY,camCfg.vmZ) end
    end)

    if AB.on then
        local CC=Mods.CameraController
        if CC then
            if abDoReact then
                abReactT=abReactT-dt
                if abReactT<=0 then abDoReact=false end
            end
            if not abDoReact then
                if abTgt and not abValid(abTgt) then
                    abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0
                end
                if not abTgt then
                    abTgt=abFind()
                    if abTgt then
                        abLockT=0;abDoReact=true;abReactT=AB.reactTime/1000
                        abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0
                    end
                end
                if abTgt then
                    abLockT=abLockT+dt
                    if abLockT>AB.maxLock then
                        abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0
                    elseif inFov(abTgt,abEffFov()) then
                        pcall(function()
                            local ap=getPred(abTgt)
                            local du=(ap-cam.CFrame.Position).Unit
                            local tR=Vector2.new(math.asin(math.clamp(du.Y,-1,1)),math.atan2(-du.X,-du.Z))
                            local cur=CC.Rotation
                            local sp=cam:WorldToViewportPoint(ap)
                            local sd=(Vector2.new(sp.X,sp.Y)-getScr()).Magnitude
                            local nr=smartLock(tR,cur,dt,sd,abEffFov())
                            CC:ApplyRotationDelta(Vector2.new(nr.X-cur.X,angDiff(cur.Y,nr.Y)))
                        end)
                    else
                        abTgt=nil;abLockT=0;abPrevPos=nil;abCurveStart=nil;abCurveEnd=nil;abCurveProgress=0
                    end
                end
            end
        end
    end

    if fovCfg.show then
        local center=fovCfg.useCenter and getScr() or getMouse()
        fovCirc.Visible=true;fovCirc.Color=fovCfg.color;fovCirc.Position=center
        local mr=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local orig=mr and mr.Position or cam.CFrame.Position
        fovCirc.Radius=abTgt and (isVis(orig,abTgt) and fovCfg.onTarget or fovCfg.onBarrier) or fovCfg.size
        if fovCfg.half then
            fovHalf.Visible=true;fovHalf.Color=fovCfg.color;fovHalf.Position=center;fovHalf.Radius=fovCirc.Radius*0.5
        else fovHalf.Visible=false end
        abCirc.Position=center;abCirc.Radius=abEffFov();abCirc.Visible=AB.on
    else fovCirc.Visible=false;fovHalf.Visible=false;abCirc.Visible=false end

    if silCfg.on and silCfg.showCircle then
        local center=silCfg.useCenter and getScr() or getMouse()
        silCirc.Visible=true;silCirc.Radius=silCfg.fov
        silCirc.Thickness=silCfg.circleThick;silCirc.Position=center
        local mr=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local orig=mr and mr.Position or cam.CFrame.Position
        silCirc.Color=silGetTarget(orig) and silCfg.targetColor or silCfg.circleColor
    else silCirc.Visible=false end
end)

