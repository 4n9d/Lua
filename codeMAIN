local SkyboxLeft  = Tabs.Skybox:AddLeftGroupbox("Skybox Changer")
local SkyboxRight = Tabs.Skybox:AddRightGroupbox("Info")
local origSky=nil; local skyEnabled=false

local function getSky()  return ws.Terrain:FindFirstChildOfClass("Sky") end
local function getAtmo() return ws.Terrain:FindFirstChildOfClass("Atmosphere") end

local function saveSky()
    if origSky then return end
    local s=getSky(); if not s then return end
    origSky={Bk=s.SkyboxBk,Dn=s.SkyboxDn,Ft=s.SkyboxFt,Lf=s.SkyboxLf,Rt=s.SkyboxRt,Up=s.SkyboxUp}
end

local function applySky(name)
    local d=SKYBOXES[name]; if not d then return end
    saveSky()
    local s=getSky(); if not s then s=Instance.new("Sky");s.Parent=ws.Terrain end
    s.SkyboxBk=d.Bk;s.SkyboxDn=d.Dn;s.SkyboxFt=d.Ft;s.SkyboxLf=d.Lf;s.SkyboxRt=d.Rt;s.SkyboxUp=d.Up
    local a=getAtmo()
    if d.isNight then Lighting.ClockTime=0;Lighting.Ambient=Color3.fromRGB(30,30,60);if a then a.Density=0.8;a.Color=Color3.fromRGB(0,0,30)end
    elseif d.isSpace then Lighting.ClockTime=0;Lighting.Ambient=Color3.fromRGB(10,10,20);Lighting.Brightness=0;if a then a.Density=0 end
    else Lighting.ClockTime=14;Lighting.Ambient=Color3.fromRGB(70,70,70);Lighting.Brightness=2;if a then a.Density=0.395;a.Color=Color3.fromRGB(199,170,0)end end
end

local function restoreSky()
    if not origSky then return end
    local s=getSky(); if not s then return end
    s.SkyboxBk=origSky.Bk;s.SkyboxDn=origSky.Dn;s.SkyboxFt=origSky.Ft;s.SkyboxLf=origSky.Lf;s.SkyboxRt=origSky.Rt;s.SkyboxUp=origSky.Up
    origSky=nil
end

