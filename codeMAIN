local function getSilentTarget(origin)
    local center = silentCfg.useCenter and getScr() or getMousePos()
    local best, bestDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p==lp then continue end
        local char = p.Character; if not char then continue end
        local head = bPart(char, silentCfg.part)
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health<=0 then continue end
        if (origin-head.Position).Magnitude > silentCfg.maxDist then continue end
        if silentCfg.visCheck and not isVis(origin, head) then continue end
        local sp, vis = cam:WorldToViewportPoint(head.Position)
        if not vis then continue end
        local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
        if d < silentCfg.fovSize and d < bestDist then bestDist=d; best=head end
    end
    return best
end

local function buildSilentWrapper(originalFunc)
    return function(self, origin, direction, distance, ...)
        if silentCfg.enabled and math.random(1,100)<=silentCfg.hitChance then
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            local orig = myRoot and myRoot.Position or cam.CFrame.Position
            local target = getSilentTarget(orig)
            if target then
                local pp = target.Position
                if silentCfg.prediction > 0 then
                    pcall(function()
                        local hrp = target.Parent and target.Parent:FindFirstChild("HumanoidRootPart")
                        local vel = hrp and hrp.AssemblyLinearVelocity or Vector3.zero
                        pp = target.Position + vel*(silentCfg.prediction*0.05)
                    end)
                end
                return originalFunc(self, origin, pp-origin, distance, ...)
            end
        end
        return originalFunc(self, origin, direction, distance, ...)
    end
end

local function hookSilent()
    if silentHooked or not util then return end
    local ok, mt = pcall(getrawmetatable, util)
    if ok and mt then
        origMeta = mt; origIndex = rawget(mt, "__index")
        rawset(mt, "__index", function(t, k)
            if k == "Raycast" then
                local rf
                if type(origIndex)=="function" then rf=origIndex(t,k)
                elseif type(origIndex)=="table" then rf=origIndex[k]
                else rf=rawget(t,k) end
                if rf then return buildSilentWrapper(rf) end
            end
            if type(origIndex)=="function" then return origIndex(t,k)
            elseif type(origIndex)=="table" then return origIndex[k] end
            return rawget(t,k)
        end)
        silentHooked=true; return
    end
    origRaycast = rawget(util,"Raycast") or util.Raycast
    if origRaycast then
        rawset(util,"Raycast",buildSilentWrapper(origRaycast))
        silentHooked=true
    end
end

local function unhookSilent()
    if not silentHooked then return end
    if origMeta and origIndex then
        pcall(function() rawset(origMeta,"__index",origIndex) end)
        origMeta=nil; origIndex=nil
    elseif origRaycast and util then
        pcall(function() rawset(util,"Raycast",origRaycast) end)
        origRaycast=nil
    end
    silentHooked=false
end

