local function getBox(hrp,head)
    local rp=hrp.Position; local ht=head.Position+Vector3.new(0,0.6,0)
    local yT=ht.Y-rp.Y; local yB=-3; local hw=1.05
    local c3d={Vector3.new(rp.X-hw,rp.Y+yB,rp.Z-hw),Vector3.new(rp.X+hw,rp.Y+yB,rp.Z-hw),Vector3.new(rp.X-hw,rp.Y+yB,rp.Z+hw),Vector3.new(rp.X+hw,rp.Y+yB,rp.Z+hw),Vector3.new(rp.X-hw,rp.Y+yT,rp.Z-hw),Vector3.new(rp.X+hw,rp.Y+yT,rp.Z-hw),Vector3.new(rp.X-hw,rp.Y+yT,rp.Z+hw),Vector3.new(rp.X+hw,rp.Y+yT,rp.Z+hw)}
    local mnX,mnY,mxX,mxY,any=math.huge,math.huge,-math.huge,-math.huge,false
    for _,c in ipairs(c3d) do
        local sp,on=cam:WorldToViewportPoint(c)
        if on and sp.Z>0 then any=true; if sp.X<mnX then mnX=sp.X end; if sp.Y<mnY then mnY=sp.Y end; if sp.X>mxX then mxX=sp.X end; if sp.Y>mxY then mxY=sp.Y end end
    end
    if not any then return nil end
    local vx,vy=cam.ViewportSize.X,cam.ViewportSize.Y
    mnX=math.clamp(mnX,0,vx);mnY=math.clamp(mnY,0,vy);mxX=math.clamp(mxX,0,vx);mxY=math.clamp(mxY,0,vy)
    local w,h=mxX-mnX,mxY-mnY
