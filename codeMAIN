local function cosmeticIsForWeapon(cosmeticData, weaponName)
    if not cosmeticData or not weaponName then return false end
    if cosmeticData.Universal == true then return true end
    local w = cosmeticData.Weapon or cosmeticData.Item or cosmeticData.WeaponName or cosmeticData.ItemName
    if w then
        if type(w) == "string" then
            if w == weaponName then return true end
        elseif type(w) == "table" then
            for _, name in pairs(w) do
                if tostring(name) == weaponName then return true end
            end
        end
    end
    local ws = cosmeticData.Weapons or cosmeticData.Items or cosmeticData.WeaponNames or cosmeticData.ItemNames or cosmeticData.AppliesTo
    if ws and type(ws) == "table" then
        for _, name in pairs(ws) do
            if tostring(name) == weaponName then return true end
        end
    end
    local compat = cosmeticData.Compatibility or cosmeticData.CompatibleWeapons or cosmeticData.SupportedWeapons
    if compat and type(compat) == "table" then
        if compat[weaponName] then return true end
        for _, name in pairs(compat) do
            if tostring(name) == weaponName then return true end
        end
    end
    return false
end

local function buildCosmeticList(cosmeticType, weaponName)
    local list = {"None"}
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return list end
    local matches = {}
    local hasWeaponSpecific = false
    for name, data in pairs(CosmeticLibrary.Cosmetics) do
        if data and data.Type == cosmeticType then
            if weaponName then
                if cosmeticIsForWeapon(data, weaponName) then
                    table.insert(matches, name); hasWeaponSpecific = true
                end
            else
                table.insert(matches, name)
            end
        end
    end
    if cosmeticType == "Skin" then
        table.sort(matches)
        for _, n in ipairs(matches) do table.insert(list, n) end
        return list
    end
    if not hasWeaponSpecific and weaponName then
        for name, data in pairs(CosmeticLibrary.Cosmetics) do
            if data and data.Type == cosmeticType then table.insert(matches, name) end
        end
    end
    table.sort(matches)
    for _, n in ipairs(matches) do table.insert(list, n) end
    return list
end

