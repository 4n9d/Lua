-- =============================================
--   ESP Render — called every RenderStepped
--   No throttling — runs at full framerate
--   This is the key fix for smooth ESP
-- =============================================

local function renderESP()
    if not espCfg.enabled then
        -- Hide all and return fast
        for _,obj in pairs(espPool) do hideESP(obj) end
        return
    end

    local camPos  = cam.CFrame.Position
    local myRoot  = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local myPos   = myRoot and myRoot.Position or camPos

    for _,p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end

        -- Create pool entry if missing
        if not espPool[p] then createESPForPlayer(p) end
        local obj = espPool[p]

        -- Early exit checks
        if espCfg.teamCheck and sameTm(p) then hideESP(obj); continue end

        local char = p.Character
        if not char then hideESP(obj); continue end

        local hum  = char:FindFirstChildOfClass("Humanoid")
        local hrp  = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")

        if not hum or not hrp or not head or hum.Health <= 0 then
            hideESP(obj); continue
        end

        local dist = (myPos - hrp.Position).Magnitude
        if dist > espCfg.maxDist then hideESP(obj); continue end

        -- Check if on screen via head position
        local headSP, headOn = cam:WorldToViewportPoint(head.Position)
        if not headOn or headSP.Z <= 0 then hideESP(obj); continue end

        -- Visibility (only compute if needed)
        local visible = false
        if espCfg.visibleOnly or espCfg.box then
            visible = isVis(camPos, head)
        end
        if espCfg.visibleOnly and not visible then hideESP(obj); continue end

        -- Get smooth bounding box (every frame = no lag)
        local bx, by, bw, bh = getBox(char)
        if not bx then hideESP(obj); continue end

        local boxCol    = visible and espCfg.boxColorVisible or espCfg.boxColorEnemy
        local outThick  = espCfg.boxThickness + (espCfg.resizeOutline and math.clamp(math.floor(400/math.max(dist,1)),1,4) or 1)
        local bThick    = espCfg.boxThickness

        -- ── BOX ──
        if espCfg.box then
            -- Outline
            local oc = espCfg.outlineColor
            local ot = outThick + 1
            obj.oT.From=Vector2.new(bx-1,by-1);     obj.oT.To=Vector2.new(bx+bw+1,by-1);     obj.oT.Color=oc;obj.oT.Thickness=ot;obj.oT.Visible=true
            obj.oB.From=Vector2.new(bx-1,by+bh+1);  obj.oB.To=Vector2.new(bx+bw+1,by+bh+1);  obj.oB.Color=oc;obj.oB.Thickness=ot;obj.oB.Visible=true
            obj.oL.From=Vector2.new(bx-1,by-1);     obj.oL.To=Vector2.new(bx-1,by+bh+1);     obj.oL.Color=oc;obj.oL.Thickness=ot;obj.oL.Visible=true
            obj.oR.From=Vector2.new(bx+bw+1,by-1);  obj.oR.To=Vector2.new(bx+bw+1,by+bh+1);  obj.oR.Color=oc;obj.oR.Thickness=ot;obj.oR.Visible=true
            -- Box
            obj.bT.From=Vector2.new(bx,by);     obj.bT.To=Vector2.new(bx+bw,by);     obj.bT.Color=boxCol;obj.bT.Thickness=bThick;obj.bT.Visible=true
            obj.bB.From=Vector2.new(bx,by+bh);  obj.bB.To=Vector2.new(bx+bw,by+bh);  obj.bB.Color=boxCol;obj.bB.Thickness=bThick;obj.bB.Visible=true
            obj.bL.From=Vector2.new(bx,by);     obj.bL.To=Vector2.new(bx,by+bh);     obj.bL.Color=boxCol;obj.bL.Thickness=bThick;obj.bL.Visible=true
            obj.bR.From=Vector2.new(bx+bw,by);  obj.bR.To=Vector2.new(bx+bw,by+bh);  obj.bR.Color=boxCol;obj.bR.Thickness=bThick;obj.bR.Visible=true
        else
            obj.bT.Visible=false;obj.bB.Visible=false;obj.bL.Visible=false;obj.bR.Visible=false
            obj.oT.Visible=false;obj.oB.Visible=false;obj.oL.Visible=false;obj.oR.Visible=false
        end

        -- ── FILL ──
        if espCfg.fill then
            obj.fill.Position=Vector2.new(bx,by);obj.fill.Size=Vector2.new(bw,bh)
            obj.fill.Color=espCfg.fillColor;obj.fill.Transparency=espCfg.fillTransparency
            obj.fill.Visible=true
        else obj.fill.Visible=false end

        -- ── SKELETON ──
        if espCfg.skeleton then
            local isR6    = char:FindFirstChild("Torso") ~= nil
            local boneDef = isR6 and SKELETON_R6 or SKELETON_R15
            for i, boneNames in ipairs(boneDef) do
                local pA  = char:FindFirstChild(boneNames[1])
                local pB  = char:FindFirstChild(boneNames[2])
                local ln  = obj.bones[i]
                if pA and pB and ln then
                    local spA, onA = cam:WorldToViewportPoint(pA.Position)
                    local spB, onB = cam:WorldToViewportPoint(pB.Position)
                    if onA and onB and spA.Z > 0 and spB.Z > 0 then
                        ln.From=Vector2.new(spA.X,spA.Y); ln.To=Vector2.new(spB.X,spB.Y)
                        ln.Color=espCfg.skeletonColor; ln.Thickness=espCfg.skelThick
                        ln.Visible=true
                    else ln.Visible=false end
                elseif ln then ln.Visible=false end
            end
            -- Hide unused bone lines
            for i=#boneDef+1, MAX_BONES do
                if obj.bones[i] then obj.bones[i].Visible=false end
            end
        else
            for _,bone in ipairs(obj.bones) do bone.Visible=false end
        end

        -- ── NAME ──
        -- Positioned above box, always visible
        if espCfg.name then
            local nameY = by - espCfg.nameSize - 3
            obj.nameTag.Text     = p.DisplayName ~= "" and p.DisplayName or p.Name
            obj.nameTag.Size     = espCfg.nameSize
            obj.nameTag.Color    = espCfg.nameColor
            obj.nameTag.Position = Vector2.new(bx+bw/2, nameY)
            obj.nameTag.Visible  = true
        else obj.nameTag.Visible=false end

        -- ── WEAPON ──
        if espCfg.weapon then
            local nameOff = espCfg.name and espCfg.nameSize+2 or 0
            obj.weaponTag.Text     = "["..getWeapon(char).."]"
            obj.weaponTag.Size     = espCfg.weaponSize
            obj.weaponTag.Color    = espCfg.weaponColor
            obj.weaponTag.Position = Vector2.new(bx+bw/2, by - espCfg.weaponSize - 3 - nameOff)
            obj.weaponTag.Visible  = true
        else obj.weaponTag.Visible=false end

        -- ── DISTANCE ──
        if espCfg.distance then
            obj.distTag.Text     = math.floor(dist).."m"
            obj.distTag.Size     = espCfg.distSize
            obj.distTag.Color    = espCfg.distColor
            obj.distTag.Position = Vector2.new(bx+bw/2, by+bh+3)
            obj.distTag.Visible  = true
        else obj.distTag.Visible=false end

        -- ── HEALTH BAR ──
        if espCfg.healthBar then
            local hp  = math.clamp(hum.Health,0,hum.MaxHealth)
            local pct = hum.MaxHealth>0 and hp/hum.MaxHealth or 0
            local hc  = getHPColor(pct)
            local bW  = espCfg.hpWidth
            local bO  = espCfg.hpOffset
            local s   = espCfg.healthBarStyle

            local bgF,bgT,fgF,fgT

            if s=="Left" then
                local x = bx - bO - bW
                bgF=Vector2.new(x,by);         bgT=Vector2.new(x,by+bh)
                fgF=Vector2.new(x,by+bh);      fgT=Vector2.new(x,by+bh-bh*pct)
            elseif s=="Right" then
                local x = bx+bw+bO+bW
                bgF=Vector2.new(x,by);         bgT=Vector2.new(x,by+bh)
                fgF=Vector2.new(x,by+bh);      fgT=Vector2.new(x,by+bh-bh*pct)
            elseif s=="Bottom" then
                local y = by+bh+bO+bW
                bgF=Vector2.new(bx,y);         bgT=Vector2.new(bx+bw,y)
                fgF=Vector2.new(bx,y);         fgT=Vector2.new(bx+bw*pct,y)
            else -- Top
                local y = by-bO-bW
                bgF=Vector2.new(bx,y);         bgT=Vector2.new(bx+bw,y)
                fgF=Vector2.new(bx,y);         fgT=Vector2.new(bx+bw*pct,y)
            end

            obj.hpBg.From=bgF;obj.hpBg.To=bgT;obj.hpBg.Thickness=bW+2;obj.hpBg.Color=Color3.new(0,0,0);obj.hpBg.Visible=true
            obj.hpFg.From=fgF;obj.hpFg.To=fgT;obj.hpFg.Thickness=bW;  obj.hpFg.Color=hc;            obj.hpFg.Visible=true
        else obj.hpBg.Visible=false;obj.hpFg.Visible=false end
    end

    -- Clean up pool entries for players who left
    for p in pairs(espPool) do
        if not p.Parent then destroyESPForPlayer(p) end
    end
end

