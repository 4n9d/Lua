local function rageGetClosest()
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil,nil end
    local target,char,dist = nil,nil,math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v~=lp and v.Character and v.Character:FindFirstChild("Head") then
            local mag = (lp.Character.HumanoidRootPart.Position-v.Character.Head.Position).Magnitude
            if mag<dist then dist=mag; target=v.Character.Head; char=v.Character end
        end
    end
    return target, char
end

local function rageCalcPoint(origin,targetPos,targetChar)
    ray_params.FilterDescendantsInstances={lp.Character,targetChar}
    if not ws:Raycast(origin,targetPos-origin,ray_params) then return origin,nil end
    for _,offset in next,rageCfg.vectors do
        local sp = origin+offset
        if not ws:Raycast(sp,targetPos-sp,ray_params) then return sp,offset.Y end
    end
    return nil,nil
end

local function improvedCalcPoint(origin,targetPos,targetChar)
    ray_params.FilterDescendantsInstances={lp.Character,targetChar}
    local function tryP(sp)
        local r = ws:Raycast(sp,targetPos-sp,ray_params)
        return r==nil or r.Instance:IsDescendantOf(targetChar)
    end
    if tryP(origin) then return origin,nil end
    for _,offset in next,rageCfg.vectors do
        local sp = origin+offset
        if tryP(sp) then return sp,offset.Y end
    end
    if rageCfg.improv.multiPass then
        for _,offset in next,rageCfg.vectors do
            for angle=-45,45,rageCfg.improv.scanAngle do
                local rad = math.rad(angle)
                local sp = origin+Vector3.new(
                    offset.X*math.cos(rad)-offset.Z*math.sin(rad),
                    offset.Y,
                    offset.X*math.sin(rad)+offset.Z*math.cos(rad)
                )
                if tryP(sp) then return sp,offset.Y end
            end
        end
    end
    if rageCfg.improv.spiralScan then
        for layer=1,4 do
            local h=layer*8
            for s=0,11 do
                local a=(s/12)*math.pi*2
                local sp = origin+Vector3.new(math.cos(a)*2*layer,h,math.sin(a)*2*layer)
                if tryP(sp) then return sp,h end
            end
        end
    end
    local sides = {
        Vector3.new(2,0,0),Vector3.new(-2,0,0),Vector3.new(0,0,2),Vector3.new(0,0,-2),
        Vector3.new(3,8,0),Vector3.new(-3,8,0),Vector3.new(0,8,3),Vector3.new(0,8,-3)
    }
    for _,side in next,sides do
        local sp = origin+side
        if tryP(sp) then return sp,side.Y end
    end
    if rageCfg.improv.adaptDist then
        local scale = math.clamp((origin-targetPos).Magnitude/50,0.5,3)
        for _,offset in next,rageCfg.vectors do
            local sc = Vector3.new(offset.X*scale,offset.Y*scale,offset.Z*scale)
            local sp = origin+sc
            if tryP(sp) then return sp,sc.Y end
        end
    end
    return nil,nil
end

local function startRagebot()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    rageRunning=false
    rageConn = RunService.Heartbeat:Connect(function()
        if not rageCfg.enabled or not lp.Character or rageRunning then return end
        local root = lp.Character:FindFirstChild("HumanoidRootPart"); if not root then return end
        if not FighterController or not FighterController.LocalFighter then return end
