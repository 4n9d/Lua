            sL(o.bT,bx,by,bx+bw,by,bc);sL(o.bB,bx,by+bh,bx+bw,by+bh,bc)
            sL(o.bL,bx,by,bx,by+bh,bc);sL(o.bR,bx+bw,by,bx+bw,by+bh,bc)
            o.cTLh.Visible=false;o.cTLv.Visible=false;o.cTRh.Visible=false;o.cTRv.Visible=false
            o.cBLh.Visible=false;o.cBLv.Visible=false;o.cBRh.Visible=false;o.cBRv.Visible=false
        elseif espCfg.corners then
            o.bT.Visible=false;o.bB.Visible=false;o.bL.Visible=false;o.bR.Visible=false
            local cl=math.floor(math.min(bw,bh)*espCfg.cornerLen)
            sL(o.cTLh,bx,by,bx+cl,by,bc);sL(o.cTLv,bx,by,bx,by+cl,bc)
            sL(o.cTRh,bx+bw-cl,by,bx+bw,by,bc);sL(o.cTRv,bx+bw,by,bx+bw,by+cl,bc)
            sL(o.cBLh,bx,by+bh,bx+cl,by+bh,bc);sL(o.cBLv,bx,by+bh-cl,bx,by+bh,bc)
            sL(o.cBRh,bx+bw-cl,by+bh,bx+bw,by+bh,bc);sL(o.cBRv,bx+bw,by+bh-cl,bx+bw,by+bh,bc)
        else
            for _,k in ipairs({"bT","bB","bL","bR","cTLh","cTLv","cTRh","cTRv","cBLh","cBLv","cBRh","cBRv"}) do o[k].Visible=false end
        end

