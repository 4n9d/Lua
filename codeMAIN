local function loadSkins()
    if not readfile or not isfile or not isfile(skinPath) then return end
    pcall(function()
        local d=HttpService:JSONDecode(readfile(skinPath))
        equipped=d.equipped or {}
        favorites=d.favorites or {}
    end)
end

local function equipSkin(w,ct,cn)
    if not w then return end
    equipped[w]=equipped[w] or {}
    if not cn or cn=="None" then
        equipped[w][ct]=nil
        if not next(equipped[w]) then equipped[w]=nil end
    else
        equipped[w][ct]=cn
    end
    saveSkins()
end

local function installSkinHook()
    if skinHooked then return end
    skinHooked=true
    task.spawn(function()
        task.wait(1)
        if not hookmetamethod or not Rem.Equip then return end
        local oldNC; oldNC=hookmetamethod(game,"__namecall",function(self,...)
            if getnamecallmethod()~="FireServer" then return oldNC(self,...) end
            local args={...}
            if Rem.Equip and self==Rem.Equip then
                local w,ct,cn=args[1],args[2],args[3]
                equipped[w]=equipped[w] or {}
                if not cn or cn=="None" then
                    equipped[w][ct]=nil
                    if not next(equipped[w]) then equipped[w]=nil end
                else
                    equipped[w][ct]=cn
                end
                saveSkins(); return
            end
            if Rem.Favorite and self==Rem.Favorite then
                favorites[args[1]]=favorites[args[1]] or {}
                favorites[args[1]][args[2]]=args[3] or nil
                saveSkins(); return
            end
            return oldNC(self,...)
        end)
    end)
end

