local function abEffFov()
    return AB.dynFov and AB.fov*(cam.FieldOfView/70) or AB.fov
end

local function abTgtValid(pt)
    if not pt or not pt.Parent then return false end
    local h = pt.Parent:FindFirstChildOfClass("Humanoid")
    if not h or h.Health<=0 then return false end
    if not inFov(pt, abEffFov()) then return false end
    if AB.vis and not isVis(cam.CFrame.Position, pt) then return false end
    if AB.team then
        local p = Players:GetPlayerFromCharacter(pt.Parent)
        if p and sameTm(p) then return false end
    end
    return true
end

local function abFind()
    local center = AB.useCenter and getScr() or getMousePos()
    local fv = abEffFov()
    local best, bd = nil, fv
    for _, p in ipairs(Players:GetPlayers()) do
        if p==lp then continue end
        if AB.team and sameTm(p) then continue end
        local chr = p.Character
        if not chr then continue end
        local hm = chr:FindFirstChildOfClass("Humanoid")
        if not hm or hm.Health<=0 then continue end
        local pt = bPart(chr, AB.part)
        if not pt then continue end
        local sp, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X,sp.Y)-center).Magnitude
        if d < bd then
            if AB.vis and not isVis(cam.CFrame.Position, pt) then continue end
            bd=d; best=pt
        end
    end
    return best
end

local function getPredictedPos(pt)
    local now = tick()
    local pos = pt.Position
    if abPrevPos and (now-abPrevTick)>0 then
        local vel = (pos-abPrevPos)/(now-abPrevTick)
        pos = pos + vel*(0.08*AB.speedAttack)
    end
    abPrevPos=pt.Position; abPrevTick=now
    return pos
end

local function applySmartLock(tRot, cur, dt, screenDist, fovRadius)
    local distFactor = AB.speed
    if fovRadius>0 then
        local norm = math.clamp(screenDist/fovRadius,0,1)
        distFactor = AB.speed+(AB.speedScaleFov/100)*(1-norm)*math.max(AB.speedAttack-AB.speed,0)
    end
    local eff    = math.clamp(distFactor,0.01,5)
    local factor = math.clamp(eff*dt*6,0,1)
    if AB.lockMode=="Soft" or AB.lockMode=="Magnet" then
        return Vector2.new(cur.X+(tRot.X-cur.X)*factor, cur.Y+angDiff(cur.Y,tRot.Y)*factor)
    else
        local dist = math.sqrt((tRot.X-cur.X)^2+angDiff(cur.Y,tRot.Y)^2)
        if abCurveStart==nil or dist>0.5 then abCurveStart=cur; abCurveProgress=0 end
        abCurveEnd=tRot
        abCurveProgress=math.clamp(abCurveProgress+(AB.curvePct/100)*3*eff*dt,0,1)
        local curved = abCurveProgress^2*(3-2*abCurveProgress)
        local nP = abCurveStart.X+(abCurveEnd.X-abCurveStart.X)*curved
        local nY = abCurveStart.Y+angDiff(abCurveStart.Y,abCurveEnd.Y)*curved
        if abCurveProgress>=1 then abCurveStart=nil; abCurveProgress=0 end
        return Vector2.new(nP,nY)
    end
end

