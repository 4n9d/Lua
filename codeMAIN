local function applySkybox(name)
    local d=SKYBOXES[name]; if not d then return end
    if not origSky then
        local s=ws.Terrain:FindFirstChildOfClass("Sky")
        if s then origSky={Bk=s.SkyboxBk,Dn=s.SkyboxDn,Ft=s.SkyboxFt,Lf=s.SkyboxLf,Rt=s.SkyboxRt,Up=s.SkyboxUp} end
    end
    local s=ws.Terrain:FindFirstChildOfClass("Sky")
    if not s then s=Instance.new("Sky"); s.Parent=ws.Terrain end
    s.SkyboxBk=d.Bk; s.SkyboxDn=d.Dn; s.SkyboxFt=d.Ft
    s.SkyboxLf=d.Lf; s.SkyboxRt=d.Rt; s.SkyboxUp=d.Up
    local a=ws.Terrain:FindFirstChildOfClass("Atmosphere")
    if d.isNight then
        Lighting.ClockTime=0; Lighting.Ambient=Color3.fromRGB(30,30,60)
        if a then a.Density=0.8 end
    elseif d.isSpace then
        Lighting.ClockTime=0; Lighting.Ambient=Color3.fromRGB(10,10,20); Lighting.Brightness=0
    else
        Lighting.ClockTime=14; Lighting.Ambient=Color3.fromRGB(70,70,70); Lighting.Brightness=2
    end
end

local function restoreSky()
    if not origSky then return end
    local s=ws.Terrain:FindFirstChildOfClass("Sky"); if not s then origSky=nil; return end
    s.SkyboxBk=origSky.Bk; s.SkyboxDn=origSky.Dn; s.SkyboxFt=origSky.Ft
    s.SkyboxLf=origSky.Lf; s.SkyboxRt=origSky.Rt; s.SkyboxUp=origSky.Up
    origSky=nil
end

