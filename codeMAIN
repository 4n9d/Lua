            elseif s=="Bottom" then local y=by+bh+bO+bW;bgF=Vector2.new(bx,y);bgT=Vector2.new(bx+bw,y);fgF=Vector2.new(bx,y);fgT=Vector2.new(bx+bw*pct,y)
            else local y=by-bO-bW;bgF=Vector2.new(bx,y);bgT=Vector2.new(bx+bw,y);fgF=Vector2.new(bx,y);fgT=Vector2.new(bx+bw*pct,y) end
            o.hpBg.From=bgF;o.hpBg.To=bgT;o.hpBg.Thickness=bW+2;o.hpBg.Color=Color3.new(0,0,0);o.hpBg.Visible=true
