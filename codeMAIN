-- =============================================
--   MAIN LOOP — RenderStepped
-- =============================================

local frameCount,wTimer = 0,0

RunService.RenderStepped:Connect(function(dt)
    cam = ws.CurrentCamera

    -- FPS counter
    frameCount = frameCount + 1
    wTimer = wTimer + dt

    -- ESP
    pcall(renderESP)

    -- Camera effects
    pcall(function()
        if not CameraController then return end
        if camCfg.fovEnabled then CameraController._base_fov=camCfg.fovValue end
        if camCfg.noShake then CameraController._shake_enabled=false; CameraController.ShakeCFrame=CFrame.identity end
        if camCfg.noSway then
            CameraController._sway_spring.Value=Vector2.zero
            CameraController._sway_spring.Target=Vector2.zero
        end
        if camCfg.noBobbing then
            CameraController._bobbing_speed_spring.Target=0
            CameraController._bobbing_speed_spring.Value=0
            CameraController._bobbing_value_spring.Target=0
            CameraController._bobbing_value_spring.Value=0
        end
        if camCfg.noJumpEffect then
            CameraController._jump_spring.Target=0
            CameraController._jump_spring.Value=0
        end
        if camCfg.noSlideTilt then
            CameraController._sliding_spring.Target=0
            CameraController._sliding_spring.Value=0
        end
        if camCfg.forceCrosshair then CameraController._crosshair_disabled=false end
        if camCfg.sensOverride then
            CameraController._camera_sensitivity=camCfg.sensValue
            CameraController._camera_sensitivity_ads_multiplier=camCfg.sensADS
            CameraController._camera_sensitivity_ads_multiplier_scoped=camCfg.sensScoped
            CameraController._camera_sensitivity_x=camCfg.sensX
            CameraController._camera_sensitivity_y=camCfg.sensY
        end
        if camCfg.viewmodelEnabled then
            CameraController.ViewModelOffsetCFrame=CFrame.new(camCfg.vmX,camCfg.vmY,camCfg.vmZ)
        end
    end)

    -- Aimbot
    if AB.on and CameraController then
        if abDoReact then
            abReactT=abReactT-dt
            if abReactT<=0 then abDoReact=false end
        end
        if not abDoReact then
            if abTgt and not abTgtValid(abTgt) then
                abTgt=nil; abLockT=0; abPrevPos=nil
                abCurveStart=nil; abCurveEnd=nil; abCurveProgress=0
            end
            if not abTgt then
                abTgt=abFind()
                if abTgt then
                    abLockT=0; abDoReact=true; abReactT=AB.reactTime/1000
                    abPrevPos=nil; abCurveStart=nil; abCurveEnd=nil; abCurveProgress=0
                end
            end
            if abTgt then
                abLockT=abLockT+dt
                if abLockT>AB.maxLock then
                    abTgt=nil; abLockT=0; abPrevPos=nil
                    abCurveStart=nil; abCurveEnd=nil; abCurveProgress=0
                elseif inFov(abTgt,abEffFov()) then
                    pcall(function()
                        local aimPos=getPredictedPos(abTgt)
                        local du=(aimPos-cam.CFrame.Position).Unit
                        local tRot=Vector2.new(
                            math.asin(math.clamp(du.Y,-1,1)),
                            math.atan2(-du.X,-du.Z)
                        )
                        local cur=CameraController.Rotation
                        local sp,_=cam:WorldToViewportPoint(aimPos)
                        local sd=(Vector2.new(sp.X,sp.Y)-getScr()).Magnitude
                        local newRot=applySmartLock(tRot,cur,dt,sd,abEffFov())
                        CameraController:ApplyRotationDelta(Vector2.new(
                            newRot.X-cur.X, angDiff(cur.Y,newRot.Y)
                        ))
                    end)
                else
                    abTgt=nil; abLockT=0; abPrevPos=nil
                    abCurveStart=nil; abCurveEnd=nil; abCurveProgress=0
                end
            end
        end
    end

    -- FOV circle
    if fovCfg.visible then
        local center = fovCfg.useCenter and getScr() or getMousePos()
        fovCircle.Visible=true; fovCircle.Color=fovCfg.color; fovCircle.Position=center
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local orig = myRoot and myRoot.Position or cam.CFrame.Position
        fovCircle.Radius = abTgt and (isVis(orig,abTgt) and fovCfg.onTarget or fovCfg.onBarrier) or fovCfg.fovSize
        if fovCfg.half then
            fovHalf.Visible=true; fovHalf.Color=fovCfg.color
            fovHalf.Position=center; fovHalf.Radius=fovCircle.Radius*0.5
        else fovHalf.Visible=false end
        abCirc.Position=center; abCirc.Radius=abEffFov(); abCirc.Visible=AB.on and AB.drawFov
    else
        fovCircle.Visible=false; fovHalf.Visible=false; abCirc.Visible=false
    end

    -- Silent FOV circle
    if silentCfg.enabled and silentCfg.circleVisible then
        local center = silentCfg.useCenter and getScr() or getMousePos()
        silentCircle.Visible=true; silentCircle.Radius=silentCfg.fovSize
        silentCircle.Thickness=silentCfg.circleThick; silentCircle.Position=center
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local orig = myRoot and myRoot.Position or cam.CFrame.Position
        silentCircle.Color = getSilentTarget(orig) and silentCfg.targetColor or silentCfg.circleColor
    else
        silentCircle.Visible=false
    end
end)

