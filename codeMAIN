local function rageClosest()
    if not lp.Character then return nil,nil end
    local root = lp.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil,nil end
    local tgt,char,best = nil,nil,math.huge
    for _,v in pairs(Players:GetPlayers()) do
        if v~=lp and v.Character then
            local h = v.Character:FindFirstChild("Head")
            if h then
                local d=(root.Position-h.Position).Magnitude
                if d<best then best=d; tgt=h; char=v.Character end
            end
        end
    end
    return tgt,char
end

local function tryPoint(targetPos, targetChar, sp)
    rRp.FilterDescendantsInstances={lp.Character,targetChar}
    local r=ws:Raycast(sp,targetPos-sp,rRp)
    return r==nil or r.Instance:IsDescendantOf(targetChar)
end

local function rageCalc(origin, targetPos, targetChar)
    rRp.FilterDescendantsInstances={lp.Character,targetChar}
    if tryPoint(targetPos,targetChar,origin) then return origin,nil end
    for _,off in next,rageCfg.vectors do
        local sp=origin+off
        if tryPoint(targetPos,targetChar,sp) then return sp,off.Y end
    end
    if rageCfg.improved and rageCfg.multiPass then
        for _,off in next,rageCfg.vectors do
            for a=-45,45,rageCfg.scanAngle do
                local r2=math.rad(a)
                local sp=origin+Vector3.new(off.X*math.cos(r2)-off.Z*math.sin(r2),off.Y,off.X*math.sin(r2)+off.Z*math.cos(r2))
                if tryPoint(targetPos,targetChar,sp) then return sp,off.Y end
            end
        end
    end
    if rageCfg.improved and rageCfg.spiral then
        for layer=1,4 do local h=layer*8
            for s=0,11 do
                local a=(s/12)*math.pi*2
                local sp=origin+Vector3.new(math.cos(a)*2*layer,h,math.sin(a)*2*layer)
                if tryPoint(targetPos,targetChar,sp) then return sp,h end
            end
        end
    end
    return nil,nil
end

local function startRage()
    if rageConn then rageConn:Disconnect() end
    rageRunning=false
    rageConn=RunService.Heartbeat:Connect(function()
        if not rageCfg.on or rageRunning then return end
        if not lp.Character then return end
        local FC = Mods.FighterController
        if not FC or not FC.LocalFighter then return end
        local item = FC.LocalFighter.EquippedItem; if not item then return end
        local tp,tc=rageClosest(); if not tp or not tc then return end
        local cf=cam.CFrame
        local manip,height=rageCalc(cf.Position,tp.Position,tc)
        if not manip then return end
        rageRunning=true
        task.spawn(function()
            pcall(function()
                local u=Mods.util; local e=Mods.enums; local R=Rem.UseItem
                if not u or not e or not R then rageRunning=false; return end
                local so=height and Vector3.new(cf.Position.X,cf.Position.Y+height,cf.Position.Z) or cf.Position
                local cd={}
                cd[utf8.char(1)]={
                    [utf8.char(0)]=u:EncodeCFrame(CFrame.lookAt(so,tp.Position)),
                    [utf8.char(1)]=u:EncodeCFrame(CFrame.lookAt(tp.Position,so)),
                    [utf8.char(2)]=tp,
                    [utf8.char(3)]=u:EncodeCFrame(tp.CFrame:ToObjectSpace(CFrame.new(tp.Position)))
                }
                R:FireServer(item:Get("ObjectID"),e:ToEnum("StartShooting"),cd,nil)
            end)
            rageRunning=false
        end)
    end)
end

local function stopRage()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    rageCfg.on=false; rageRunning=false
end

