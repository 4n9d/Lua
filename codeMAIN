local silHooked, origRC, origMeta, origIdx = false, nil, nil, nil

local function silGetTarget(origin)
    local center = silCfg.useCenter and getScr() or getMouse()
    local best, bd = nil, math.huge
    for _,p in pairs(Players:GetPlayers()) do
        if p==lp then continue end
        local char=p.Character; if not char then continue end
        local head=bPart(char,silCfg.part)
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health<=0 then continue end
        if (origin-head.Position).Magnitude>silCfg.maxDist then continue end
        if silCfg.visCheck and not isVis(origin,head) then continue end
        local sp,vis=cam:WorldToViewportPoint(head.Position)
        if not vis then continue end
        local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude
        if d<silCfg.fov and d<bd then bd=d; best=head end
    end
    return best
end

local function silWrap(orig)
    return function(self,origin,dir,dist,...)
        if silCfg.on and math.random(1,100)<=silCfg.hitChance then
            local myR=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            local o=myR and myR.Position or cam.CFrame.Position
            local tgt=silGetTarget(o)
            if tgt then
                local pp=tgt.Position
                if silCfg.prediction>0 then
                    pcall(function()
                        local hrp=tgt.Parent and tgt.Parent:FindFirstChild("HumanoidRootPart")
                        local vel=hrp and hrp.AssemblyLinearVelocity or Vector3.zero
                        pp=tgt.Position+vel*(silCfg.prediction*0.05)
                    end)
                end
                return orig(self,origin,pp-origin,dist,...)
            end
        end
        return orig(self,origin,dir,dist,...)
    end
end

local function hookSil()
    if silHooked or not Mods.util then return end
    local ok,mt=pcall(getrawmetatable,Mods.util)
    if ok and mt then
        origMeta=mt; origIdx=rawget(mt,"__index")
        rawset(mt,"__index",function(t,k)
