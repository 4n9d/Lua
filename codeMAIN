local SKEL6={{"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},{"Torso","Left Leg"},{"Torso","Right Leg"}}
local MAXB=math.max(#SKEL15,#SKEL6)

local function nL(pr) local d=Drawing.new("Line");d.Visible=false;d.Thickness=1.5;d.Color=Color3.new(1,1,1);d.ZIndex=5;if pr then for k,v in pairs(pr) do d[k]=v end end;return d end
local function nT(pr) local d=Drawing.new("Text");d.Visible=false;d.Size=13;d.Center=true;d.Outline=true;d.Font=Drawing.Fonts.UI;d.Color=Color3.new(1,1,1);d.ZIndex=7;if pr then for k,v in pairs(pr) do d[k]=v end end;return d end
local function nSq(pr) local d=Drawing.new("Square");d.Visible=false;d.Filled=true;d.Color=Color3.new(1,1,1);d.Transparency=0.75;d.ZIndex=3;if pr then for k,v in pairs(pr) do d[k]=v end end;return d end

local function mkESP(p)
    if espPool[p] then return end
    local o={bT=nL(),bB=nL(),bL=nL(),bR=nL(),cTLh=nL({ZIndex=6}),cTLv=nL({ZIndex=6}),cTRh=nL({ZIndex=6}),cTRv=nL({ZIndex=6}),cBLh=nL({ZIndex=6}),cBLv=nL({ZIndex=6}),cBRh=nL({ZIndex=6}),cBRv=nL({ZIndex=6}),fill=nSq(),nameT=nT(),weapT=nT({Size=11,Color=Color3.fromRGB(160,160,255)}),distT=nT({Size=11,Color=Color3.fromRGB(180,180,180)}),hpBg=nL({ZIndex=5,Thickness=5,Color=Color3.new(0,0,0)}),hpFg=nL({ZIndex=6,Thickness=3,Color=Color3.fromRGB(60,220,60)}),bones={}}
