local function buildWeaponList()
    local list = {}
    for _,t in ipairs({PRIMARY_WEAPONS,SECONDARY_WEAPONS,MELEE_WEAPONS,UTILITY_WEAPONS}) do
        for _,n in ipairs(t) do table.insert(list,n) end
    end
    table.sort(list); return list
end

local function cosmeticIsForWeapon(cd, wn)
    if not cd or not wn then return false end
    if cd.Universal then return true end
    for _,f in ipairs({"Weapon","Item","WeaponName","ItemName"}) do
        local w=cd[f]
        if w then
            if type(w)=="string" and w==wn then return true end
            if type(w)=="table" then for _,n in pairs(w) do if tostring(n)==wn then return true end end end
        end
    end
    for _,f in ipairs({"Weapons","Items","WeaponNames","ItemNames","AppliesTo"}) do
        local w=cd[f]
        if w and type(w)=="table" then for _,n in pairs(w) do if tostring(n)==wn then return true end end end
    end
    return false
end

local function cloneCosmetic(name, cType, opts)
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then return nil end
    local base = CosmeticLibrary.Cosmetics[name]; if not base then return nil end
    local data={}; for k,v in pairs(base) do data[k]=v end
    data.Name=name; data.Type=data.Type or cType; data.Seed=math.random(1,1000000)
    if enums then pcall(function() local e=enums:ToEnum(name); if e then data.Enum=e; data.ObjectID=e end end) end
    if opts and opts.inverted then data.Inverted=true end
    return data
end

local function saveSkinConfig()
    if not writefile then return end
    task.spawn(function() pcall(function()
        local config={equipped={},favorites=favorites}
        for w,cs in pairs(equipped) do
            config.equipped[w]={}
            for ct,cd in pairs(cs) do
                if cd and cd.Name then
                    config.equipped[w][ct]={name=cd.Name,seed=cd.Seed,inverted=cd.Inverted}
                end
            end
        end
        if not isfolder("RivalsScript") then makefolder("RivalsScript") end
        writefile(skinConfigPath, HttpService:JSONEncode(config))
    end) end)
end

local function loadSkinConfig()
    if not readfile or not isfile or not isfile(skinConfigPath) then return end
    pcall(function()
        local config=HttpService:JSONDecode(readfile(skinConfigPath))
        if config.equipped then
            for w,cs in pairs(config.equipped) do
                equipped[w]={}
                for ct,cd in pairs(cs) do
                    local c=cloneCosmetic(cd.name,ct,{inverted=cd.inverted})
                    if c then c.Seed=cd.seed; equipped[w][ct]=c end
                end
            end
        end
        favorites=config.favorites or {}
    end)
end

local function equipCosmetic(w,ct,cn)
    if not w then return end
    equipped[w]=equipped[w]or{}
    if not cn or cn=="None" then
        equipped[w][ct]=nil
        if not next(equipped[w]) then equipped[w]=nil end
    else
        local c=cloneCosmetic(cn,ct)
        if c then equipped[w][ct]=c end
    end
    pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end)
    saveSkinConfig()
end

local function installSkinHooks()
    if skinHooksInstalled then return end
    skinHooksInstalled=true
    task.spawn(function()
        task.wait(1)
        if DataController then pcall(function()
            DataController.OwnsAllWeapons=function() return true end
            DataController.GetUnlockedWeapons=function()
                local w={}
                if ItemLibrary and ItemLibrary.Items then
                    for n,_ in pairs(ItemLibrary.Items) do if not n:find("MISSING_") then w[n]=true end end
                end
                return w
            end
        end) end
        if CosmeticLibrary then pcall(function()
            CosmeticLibrary.OwnsCosmeticNormally=function()return true end
            CosmeticLibrary.OwnsCosmeticUniversally=function()return true end
            CosmeticLibrary.OwnsCosmeticForSomething=function()return true end
            CosmeticLibrary.OwnsCosmeticForWeapon=function()return true end
            local origOC=CosmeticLibrary.OwnsCosmetic
            CosmeticLibrary.OwnsCosmetic=function(self,inv,name,wpn)
                if name and name:find("MISSING_") then return origOC(self,inv,name,wpn) end
                return true
            end
        end) end
        if DataController then pcall(function()
            local origGet=DataController.Get
            DataController.Get=function(self,key)
                local data=origGet(self,key)
                if key=="CosmeticInventory" then return setmetatable({},{__index=function() return true end}) end
                if key=="FavoritedCosmetics" then
                    local r={}
                    if data then for k,v in pairs(data) do r[k]=v end end
                    for w,f in pairs(favorites) do r[w]=r[w]or{}; for n,b in pairs(f) do r[w][n]=b end end
                    return r
                end
                return data
            end
            local origGWD=DataController.GetWeaponData
            DataController.GetWeaponData=function(self,wn)
                local data={Unlocked=true,Level=100,XP=99999}
                local od=origGWD(self,wn); if od then for k,v in pairs(od) do data[k]=v end end
                if equipped[wn] then for ct,cd in pairs(equipped[wn]) do data[ct]=cd end end
                return data
            end
        end) end
        if not hookmetamethod or not EquipCosmeticRemote then return end
        local oldNC; oldNC=hookmetamethod(game,"__namecall",function(self,...)
            if getnamecallmethod()~="FireServer" then return oldNC(self,...) end
            local args={...}
            if EquipCosmeticRemote and self==EquipCosmeticRemote then
                local wn,ct,cn=args[1],args[2],args[3]; local opts=args[4]or{}
                equipped[wn]=equipped[wn]or{}
                if not cn or cn=="None" or cn=="" then
                    equipped[wn][ct]=nil
                    if not next(equipped[wn]) then equipped[wn]=nil end
                else
                    local c=cloneCosmetic(cn,ct,{inverted=opts.IsInverted})
                    if c then equipped[wn][ct]=c end
                end
                task.spawn(function()
                    task.wait(0.1)
                    pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end)
                    saveSkinConfig()
                end)
                return
            end
            if FavoriteCosmeticRemote and self==FavoriteCosmeticRemote then
                favorites[args[1]]=favorites[args[1]]or{}
                favorites[args[1]][args[2]]=args[3]or nil
                saveSkinConfig(); return
            end
            return oldNC(self,...)
        end)
    end)
end

