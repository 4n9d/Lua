local function renderESP()
    table.clear(espValidSet)
    if not espCfg.enabled then
        for _,obj in pairs(espPool) do hideObj(obj) end
        return
    end
    local camPos = cam.CFrame.Position
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local myPos = myRoot and myRoot.Position or camPos
    for _,p in ipairs(Players:GetPlayers()) do
        if p==lp then continue end
        espValidSet[p]=true
        if not espPool[p] then createESPObjects(p) end
        local obj = espPool[p]
        if espCfg.teamCheck and sameTm(p) then hideObj(obj); continue end
        local char = p.Character; if not char then hideObj(obj); continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not hum or not hrp or not head or hum.Health<=0 then hideObj(obj); continue end
        local dist = (myPos-hrp.Position).Magnitude
        if dist>espCfg.maxDist then hideObj(obj); continue end
        local headSP,headOn = cam:WorldToViewportPoint(head.Position)
        if not headOn or headSP.Z<=0 then hideObj(obj); continue end
        local visible = false
        if espCfg.colorByVisibility or espCfg.visibleOnly then visible=isVis(camPos,head) end
        if espCfg.visibleOnly and not visible then hideObj(obj); continue end
        local bx,by,bw,bh = getBox(hrp,head)
        if not bx then hideObj(obj); continue end
        local boxCol = espCfg.colorByVisibility and (visible and espCfg.boxVisible or espCfg.boxEnemy) or espCfg.boxColor

        if espCfg.box and not espCfg.corners then
            setLine(obj.bT,bx,by,bx+bw,by,boxCol)
            setLine(obj.bB,bx,by+bh,bx+bw,by+bh,boxCol)
            setLine(obj.bL,bx,by,bx,by+bh,boxCol)
            setLine(obj.bR,bx+bw,by,bx+bw,by+bh,boxCol)
            obj.cTLh.Visible=false;obj.cTLv.Visible=false
            obj.cTRh.Visible=false;obj.cTRv.Visible=false
            obj.cBLh.Visible=false;obj.cBLv.Visible=false
            obj.cBRh.Visible=false;obj.cBRv.Visible=false
        elseif espCfg.corners then
            obj.bT.Visible=false;obj.bB.Visible=false
            obj.bL.Visible=false;obj.bR.Visible=false
            local cl = math.floor(math.min(bw,bh)*espCfg.cornerLength)
            setLine(obj.cTLh,bx,by,bx+cl,by,boxCol);setLine(obj.cTLv,bx,by,bx,by+cl,boxCol)
            setLine(obj.cTRh,bx+bw-cl,by,bx+bw,by,boxCol);setLine(obj.cTRv,bx+bw,by,bx+bw,by+cl,boxCol)
            setLine(obj.cBLh,bx,by+bh,bx+cl,by+bh,boxCol);setLine(obj.cBLv,bx,by+bh-cl,bx,by+bh,boxCol)
            setLine(obj.cBRh,bx+bw-cl,by+bh,bx+bw,by+bh,boxCol);setLine(obj.cBRv,bx+bw,by+bh-cl,bx+bw,by+bh,boxCol)
        else
            obj.bT.Visible=false;obj.bB.Visible=false;obj.bL.Visible=false;obj.bR.Visible=false
            obj.cTLh.Visible=false;obj.cTLv.Visible=false;obj.cTRh.Visible=false;obj.cTRv.Visible=false
            obj.cBLh.Visible=false;obj.cBLv.Visible=false;obj.cBRh.Visible=false;obj.cBRv.Visible=false
        end

        if espCfg.fill then
            obj.fill.Position=Vector2.new(bx,by); obj.fill.Size=Vector2.new(bw,bh)
            obj.fill.Color=espCfg.fillColor; obj.fill.Transparency=espCfg.fillTrans; obj.fill.Visible=true
        else obj.fill.Visible=false end

        if espCfg.skeleton then
            local isR6 = char:FindFirstChild("Torso")~=nil
            local bDefs = isR6 and SKEL_R6 or SKEL_R15
            for i,bdef in ipairs(bDefs) do
                local pA,pB = char:FindFirstChild(bdef[1]), char:FindFirstChild(bdef[2])
                local ln = obj.bones[i]
                if pA and pB and ln then
                    local spA,onA = cam:WorldToViewportPoint(pA.Position)
                    local spB,onB = cam:WorldToViewportPoint(pB.Position)
                    if onA and onB and spA.Z>0 and spB.Z>0 then
                        ln.From=Vector2.new(spA.X,spA.Y); ln.To=Vector2.new(spB.X,spB.Y)
                        ln.Color=espCfg.skelColor; ln.Thickness=1.5; ln.Visible=true
                    else ln.Visible=false end
                elseif ln then ln.Visible=false end
            end
            for i=#bDefs+1,MAX_BONES do if obj.bones[i] then obj.bones[i].Visible=false end end
        else for _,bone in ipairs(obj.bones) do bone.Visible=false end end

        if espCfg.name then
            obj.nameTag.Text = p.DisplayName~="" and p.DisplayName or p.Name
            obj.nameTag.Size=espCfg.nameSize; obj.nameTag.Color=espCfg.nameColor
            obj.nameTag.Position=Vector2.new(bx+bw/2, by-espCfg.nameSize-4)
            obj.nameTag.Visible=true
        else obj.nameTag.Visible=false end

        if espCfg.weapon then
            local nameOff = espCfg.name and (espCfg.nameSize+2) or 0
            obj.weaponTag.Text="["..getWeapon(char).."]"
            obj.weaponTag.Size=espCfg.weaponSize; obj.weaponTag.Color=espCfg.weaponColor
            obj.weaponTag.Position=Vector2.new(bx+bw/2, by-espCfg.weaponSize-4-nameOff)
            obj.weaponTag.Visible=true
        else obj.weaponTag.Visible=false end

        if espCfg.distance then
            obj.distTag.Text=math.floor(dist).."m"
            obj.distTag.Size=espCfg.distSize; obj.distTag.Color=espCfg.distColor
            obj.distTag.Position=Vector2.new(bx+bw/2, by+bh+4)
            obj.distTag.Visible=true
        else obj.distTag.Visible=false end

        if espCfg.healthBar then
            local hp = math.clamp(hum.Health,0,hum.MaxHealth)
            local pct = hum.MaxHealth>0 and (hp/hum.MaxHealth) or 0
            local hc = getHPColor(pct)
            local bW,bO,s = espCfg.hpBarWidth, espCfg.hpBarOffset, espCfg.healthBarStyle
            local bgF,bgT,fgF,fgT
            if s=="Left" then
                local x=bx-bO-bW
                bgF=Vector2.new(x,by); bgT=Vector2.new(x,by+bh)
                fgF=Vector2.new(x,by+bh); fgT=Vector2.new(x,by+bh-bh*pct)
            elseif s=="Right" then
                local x=bx+bw+bO+bW
                bgF=Vector2.new(x,by); bgT=Vector2.new(x,by+bh)
                fgF=Vector2.new(x,by+bh); fgT=Vector2.new(x,by+bh-bh*pct)
            elseif s=="Bottom" then
                local y=by+bh+bO+bW
                bgF=Vector2.new(bx,y); bgT=Vector2.new(bx+bw,y)
                fgF=Vector2.new(bx,y); fgT=Vector2.new(bx+bw*pct,y)
            else
                local y=by-bO-bW
                bgF=Vector2.new(bx,y); bgT=Vector2.new(bx+bw,y)
                fgF=Vector2.new(bx,y); fgT=Vector2.new(bx+bw*pct,y)
            end
            obj.hpBg.From=bgF; obj.hpBg.To=bgT; obj.hpBg.Thickness=bW+2
            obj.hpBg.Color=Color3.new(0,0,0); obj.hpBg.Visible=true
            obj.hpFg.From=fgF; obj.hpFg.To=fgT; obj.hpFg.Thickness=bW
            obj.hpFg.Color=hc; obj.hpFg.Visible=true
        else obj.hpBg.Visible=false; obj.hpFg.Visible=false end
    end
    for p in pairs(espPool) do
        if not espValidSet[p] then destroyESPObjects(p) end
    end
end

